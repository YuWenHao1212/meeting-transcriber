# OpenAI API key (required for transcription)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for summarization)
ANTHROPIC_API_KEY=sk-ant-...

# Audio device ID (optional, use `mt record --list-devices` to find)
# MT_AUDIO_DEVICE=

# Transcription language (default: zh)
# MT_LANGUAGE=zh

# Transcription model (default: gpt-4o-transcribe)
# MT_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Summary model (default: claude-sonnet-4-20250514)
# MT_SUMMARY_MODEL=claude-sonnet-4-20250514

# DashScope API key (required for Qwen3-ASR engine)
# DASHSCOPE_API_KEY=sk-...

# Azure OpenAI (required for real-time coaching prompts)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://neatoolkit-openai.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# COACHING_MODEL=gpt-4.1-nano
