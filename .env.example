# OpenAI API key (required for transcription)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for summarization)
ANTHROPIC_API_KEY=sk-ant-...

# Audio device ID (optional, use `mt record --list-devices` to find)
# MT_AUDIO_DEVICE=

# Transcription language (default: zh)
# MT_LANGUAGE=zh

# Transcription model (default: gpt-4o-transcribe)
# MT_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Summary model (default: claude-sonnet-4-20250514)
# MT_SUMMARY_MODEL=claude-sonnet-4-20250514
